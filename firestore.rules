rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidAdClick(data) {
      return data.keys().hasAll(['timestamp']) 
        && data.timestamp is timestamp
        && (data.keys().size() <= 3);
    }

    function isValidDownload(data) {
      return data.keys().hasAll(['url', 'timestamp'])
        && data.url is string && data.url.size() <= 2048
        && data.timestamp is timestamp
        && (data.keys().size() <= 4);
    }

    match /ad_clicks/{clickId} {
      allow read: if true;
      allow create: if isValidAdClick(request.resource.data) 
        && request.resource.data.timestamp == request.time;
    }

    match /downloads/{downloadId} {
      allow read: if true;
      allow create: if isValidDownload(request.resource.data)
        && request.resource.data.timestamp == request.time;
    }
  }
}
